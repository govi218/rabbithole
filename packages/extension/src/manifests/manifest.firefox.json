{
  "name": "Rabbithole",
  "description": "Track your internet rabbitholes!",
  "version": "4.9",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "rabbithole@rabbithole.land",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "src/assets/icons/logo16-dark.png",
    "32": "src/assets/icons/logo32-dark.png",
    "48": "src/assets/icons/logo48-dark.png",
    "128": "src/assets/icons/logo128-dark.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/icons/logo.png",
        "src/assets/icons/logo16.png",
        "src/assets/icons/logo32.png",
        "src/assets/icons/logo48.png",
        "src/assets/icons/logo128.png",
        "src/assets/icons/logo16-dark.png",
        "src/assets/icons/logo32-dark.png",
        "src/assets/icons/logo48-dark.png",
        "src/assets/icons/logo128-dark.png",
        "src/trail/trail.html",
        "*.js",
        "*.css",
        "assets/*",
        "src/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "chrome_url_overrides": {
    "newtab": "src/newtab/newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["src/content/index.ts"]
    }
  ],
  "background": {
    "scripts": ["src/background/index.ts"],
    "type": "module"
  },
  "options_page": "src/options/options.html",
  "action": {
    "default_icon": {
      "16": "src/assets/icons/logo16-dark.png",
      "32": "src/assets/icons/logo32-dark.png",
      "48": "src/assets/icons/logo48-dark.png",
      "128": "src/assets/icons/logo128-dark.png"
    },
    "default_popup": "src/popup/popup.html"
  },
  "permissions": ["tabs", "storage", "identity", "bookmarks", "tabGroups"],
  "host_permissions": [
    "*://*/*",
    "https://*.bsky.social/*",
    "https://public.api.bsky.app/*",
    "https://plc.directory/*"
  ]
}
