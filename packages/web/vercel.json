{
  "outputDirectory": "build",
  "rewrites": [
    { "source": "/trail/:did/:rkey", "destination": "/index.html" },
    { "source": "/burrow/:did/:rkey", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/deploy",
      "destination": "https://vercel.com/templates/svelte/watch-this"
    },
    {
      "source": "/github",
      "destination": "https://github.com/StephDietz/watch-this"
    }
  ]
}
